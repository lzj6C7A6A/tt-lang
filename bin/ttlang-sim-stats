# TT-Lang trace statistics tool (ttlang-trace-stats)
#
# Derives simulator statistics from a JSON Lines trace file produced by
# ttlang-sim --trace.  Prints the same tables as ttlang-sim --show-stats.
# Usage: ttlang-trace-stats trace.jsonl

PYTHON="${PYTHON:-python}"

exec "$PYTHON" -m sim_stats "$@"
