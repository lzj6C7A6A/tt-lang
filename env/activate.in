# tt-lang environment activation (generated by CMake)

# Check for verbose flag
_TTLANG_VERBOSE=0
if [ "${1:-}" = "-v" ] || [ "${1:-}" = "--verbose" ]; then
  _TTLANG_VERBOSE=1
fi

# Guard against re-activation.
if [ -n "${TTLANG_ENV_ACTIVATED}" ]; then
  deactivate 2>/dev/null || :
fi

# Activate the Python venv (provides correct Python version + packages).
# Prompt customization is handled by ttlang_prompt_utils.sh, sourced after
# the venv so it can wrap deactivate and cooperate with zsh themes.
if [ -f "@TTLANG_PYTHON_VENV@/bin/activate" ]; then
  VIRTUAL_ENV_DISABLE_PROMPT=1
  source "@TTLANG_PYTHON_VENV@/bin/activate"
  unset VIRTUAL_ENV_DISABLE_PROMPT
  source "@TT_LANG_HOME@/env/ttlang_prompt_utils.sh"
fi

# Set tt-lang home directory.
export TT_LANG_HOME="@TT_LANG_HOME@"
export TTLANG_HAS_DEVICE="@TTLANG_HAS_DEVICE_INT@"

# LLVM/MLIR install prefix (built from submodule or pre-provided).
export LLVM_INSTALL_DIR="@LLVM_INSTALL_DIR@"

# Add build tools, LLVM tools, and venv to PATH.
# The venv bin is added explicitly because the venv's own activate script
# hardcodes the original creation path, which may be stale after relocation.
export PATH="@CMAKE_BINARY_DIR@/bin:${TT_LANG_HOME}/bin:${LLVM_INSTALL_DIR}/bin:@TTLANG_PYTHON_VENV@/bin:$PATH"

# Python packages: built MLIR + tt-mlir + ttlang bindings, plus source trees.
export PYTHONPATH="\
@CMAKE_BINARY_DIR@/python_packages:\
${TT_LANG_HOME}/python:\
${TT_LANG_HOME}/test:\
${PYTHONPATH:-}"

# Library path for built shared libraries.
export LD_LIBRARY_PATH="@CMAKE_BINARY_DIR@/lib:${LLVM_INSTALL_DIR}/lib:${LD_LIBRARY_PATH:-}"

# tt-metal runtime
export TT_METAL_HOME="@TT_METAL_HOME@"
export TT_METAL_RUNTIME_ROOT="${TT_METAL_HOME}"
export PYTHONPATH="@TT_METAL_PYTHON_PATH@:${PYTHONPATH:-}"
export LD_LIBRARY_PATH="@TT_METAL_LIB_PATH@:${LD_LIBRARY_PATH:-}"

# Mark environment as activated.
export TTLANG_ENV_ACTIVATED=1

if [ "${_TTLANG_VERBOSE}" -ne 0 ]; then
  echo "tt-lang environment activated"
  echo "  TT_LANG_HOME:     ${TT_LANG_HOME}"
  echo "  LLVM_INSTALL_DIR: ${LLVM_INSTALL_DIR}"
  echo "  Build dir:        @CMAKE_BINARY_DIR@"
  echo "  TT_METAL_HOME:   ${TT_METAL_HOME}"
fi
